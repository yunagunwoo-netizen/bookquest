rules_version = '2';

// ============================================================
// BookQuest Firestore Security Rules
// ------------------------------------------------------------
// 주의: 이 앱은 Firebase Authentication을 사용하지 않고,
// localStorage 기반의 random uid("user_<timestamp>_<random>")를
// 클라이언트 식별자로 사용합니다 (app.html line 320).
//
// 따라서 request.auth 기반 규칙(예: request.auth.uid == userId)을
// 사용할 수 없습니다. 모든 사용자가 random uid로 read/write 합니다.
//
// 또한 랭킹/대결 상대 매칭 기능에서 users 컬렉션 전체를 read 하므로
// (app.html line 379, 9939), 데이터는 사실상 공개됩니다.
//
// 향후 Firebase Anonymous Auth(signInAnonymously)를 도입하면
// `allow read, write: if request.auth != null && request.auth.uid == userId;`
// 같은 더 strict한 규칙으로 교체하세요.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자 문서: 누구나 read/write 가능
    // (이 앱은 Firebase Auth 미사용 상태라 클라이언트 검증 없음)
    match /users/{userId} {
      allow read, write: if true;

      // 백업 서브컬렉션 (users/{uid}/backups/{date})
      match /backups/{backupId} {
        allow read, write: if true;
      }
    }

    // 그 외 모든 컬렉션은 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
